{
  "name": "url-shortener",
  "version": "1.0.0",
  "description": "URL Shortener with Click Analytics API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/url_shortener REDIS_URL=redis://localhost:6379 nodemon --exec ts-node src/index.ts"
  },
  "keywords": [
    "url-shortener",
    "analytics",
    "typescript",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "ioredis": "^5.4.1",
    "nanoid": "^3.3.7",
    "pg": "^8.13.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}